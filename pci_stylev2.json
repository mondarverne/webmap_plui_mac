{
  "version": 8,
  "name": "cadastre_simple",
  "metadata": {"maputnik:renderer": "ol"},
  "sources": {
    "pci": {
      "type": "vector",
      "tiles": [
        "https://openmaptiles.data.gouv.fr/data/cadastre/{z}/{x}/{y}.pbf"
      ],
      "scheme": "xyz"
    }
  },
  "layers": [

    {
      "id": "batiment",
      "type": "fill",
      "source": "pci",
      "source-layer": "batiments",
      "paint": {
        "fill-color": "#61696b",
        "fill-opacity": 1
      }
    },

    {
      "id": "parcelle",
      "type": "line",
      "source": "pci",
      "source-layer": "parcelles",
      "paint": {
        "line-color": "#000000",
        "line-width": 0.2
      }
    },

    {
      "id": "section",
      "type": "line",
      "source": "pci",
      "source-layer": "sections",
      "minzoom": 17,
      "paint": {
        "line-color": "#000000",
        "line-width": 0.8
      }
    },

    {
      "id": "parcelle_label",
      "type": "symbol",
      "source": "pci",
      "source-layer": "parcelles",
      "minzoom": 14,
      "layout": {
        "text-field": "{numero}",
        "text-size": 11,
        "text-anchor": "center",
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },

    {
      "id": "section_label",
      "type": "symbol",
      "source": "pci",
      "source-layer": "sections",
      "minzoom": 14,
      "layout": {
        "text-field": "{code}",
        "text-size": 14,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }

  ]
}
