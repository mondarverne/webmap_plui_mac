{
  "version": 8,
  "name": "cadastre",
  "metadata": {"maputnik:renderer": "ol"},
  "sources": {
    "pci": {
      "type": "vector",
      "tiles": [
        "https://openmaptiles.data.gouv.fr/data/cadastre/{z}/{x}/{y}.pbf"
        ],
      "scheme": "xyz"
    }
  },
  "transition": {
    "duration": 300,
    "delay": 0
  },
  "layers": 
  [
    {
      "id": "parcelle-limit",
      "type": "line",
      "source": "pci",
      "source-layer": "parcelles",
      "paint": {
        "line-color": "#323232",
        "line-width": 0.3
      },
      "layout": {"line-join": "bevel"}
    },
    {
      "id": "batiment",
      "type": "fill",
      "source": "pci",
      "source-layer": "batiments",
      "paint": {
        "fill-color": "#61696b",
        "fill-opacity": 0.8
      }
    },
    
    {
      "id": "section",
      "type": "line",
      "source": "pci",
      "source-layer": "sections",
      "paint": {
        "line-color": "#323232",
        "line-width": 0.8
      },
      "layout": {
        "line-cap": "butt",
        "line-join": "bevel"
      }
    },
    {
    "id": "section_label",
    "type": "symbol",
    "source": "pci",
    "source-layer": "sections",
    "layout": {
      "text-field": "{code}",
      "text-font": [
        "Source Sans Pro Bold Italic"
      ],
      "text-size": 5
    },
    "paint": {
      "text-color": "#323232",
      "text-halo-color": "#ffffff",
      "text-halo-width": 1
    }
    }
  ]
}













































